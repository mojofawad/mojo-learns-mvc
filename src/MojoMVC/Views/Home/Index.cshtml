@model MojoMVC.ViewModels.HomeIndexViewModel
@{
    ViewBag.Title = "Home Page";
}

<main>
    <div class="row">
        <section class="col-md-6">
            <h2>Feed from Url</h2>
            @Html.Partial("../_Partials/_Feeds", Model.WebFeeds)
        </section>
        <section class="col-md-6">
            <h2>Feed from Db</h2>
            @Html.Partial("../_Partials/_Feeds", Model.DbFeeds)
        </section>
    </div>
</main>